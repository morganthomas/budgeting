# Domain name (no protocol, no trailing slash)
DOMAIN=budget.example.com

# Strong random password for PostgreSQL
DB_PASSWORD=change_me_strong_password

# Strong random secret for session tokens (32+ characters recommended)
SESSION_SECRET=change_me_random_secret_at_least_32_characters_long

# SendGrid settings for password reset emails
SENDGRID_API_KEY=SG.your_api_key_here
EMAIL_FROM=noreply@example.com
